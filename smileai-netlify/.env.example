# ═══════════════════════════════════════════════════════════
# FRONTEND ENV VARS  →  Set in Netlify: Site → Environment Variables
# These get bundled into the JavaScript that runs in the browser.
# Only add things that are safe to be public here.
# ═══════════════════════════════════════════════════════════

# Your Google Generative AI key (already working - keep as-is)
VITE_GOOGLE_GENAI_API_KEY=your_google_genai_key_here

# Your marketplace app client_id (public - safe in frontend)
VITE_GHL_CLIENT_ID=your_ghl_client_id_here


# ═══════════════════════════════════════════════════════════
# NETLIFY FUNCTION ENV VARS  →  Set in Netlify: Site → Environment Variables
# These are only available in netlify/functions/*.mjs
# NEVER use VITE_ prefix for these - they must NOT reach the browser
# ═══════════════════════════════════════════════════════════

# Marketplace OAuth credentials
GHL_CLIENT_ID=your_ghl_client_id_here
GHL_CLIENT_SECRET=your_ghl_client_secret_here    # ← NEVER in VITE_ vars
GHL_REDIRECT_URI=https://www.smilevisionpro.ai/ghl-callback
FRONTEND_URL=https://www.smilevisionpro.ai

# Supabase (for storing tokens - use service role key, NOT anon key)
SUPABASE_URL=https://pvophjpndtqxkoygposy.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Optional Supabase Storage buckets for generated assets
SUPABASE_IMAGE_BUCKET=make-c5a5d193-smile-images
SUPABASE_VIDEO_BUCKET=ai Videos
